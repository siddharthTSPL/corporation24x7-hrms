{
  "name": "torchx-attendance-agent",
  "version": "1.0.0",
  "description": "TorchX desktop attendance tracker - tracks activity across all apps",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.torchx.agent",
    "productName": "TorchX Attendance",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "uiohook-napi": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  }
}
